$base = 'https://appsmcm101fp.iprod.local/AdminService'

Write-Host "`n--- Test 1: app list query ---" -ForegroundColor Cyan
try {
    $r1 = Invoke-RestMethod -Uri "$base/wmi/SMS_ApplicationLatest?`$select=CI_ID,LocalizedDisplayName" -UseDefaultCredentials
    Write-Host "OK - returned $($r1.value.Count) apps" -ForegroundColor Green
} catch { Write-Host "FAIL: $($_.Exception.Message)" -ForegroundColor Red }

Write-Host "`n--- Test 2: per-app detail query (suspected failure) ---" -ForegroundColor Cyan
try {
    $r2 = Invoke-RestMethod -Uri "$base/wmi/SMS_Application(16796464)?`$select=SDMPackageXML" -UseDefaultCredentials
    Write-Host "OK - XML length: $($r2.value.SDMPackageXML.Length)" -ForegroundColor Green
} catch { Write-Host "FAIL: $($_.Exception.Message)" -ForegroundColor Red }

Write-Host "`n--- Test 3: detail query via [System.Uri] (the fix) ---" -ForegroundColor Cyan
try {
    $u = [System.Uri]::new("$base/wmi/SMS_Application(16796464)?`$select=SDMPackageXML")
    $r3 = Invoke-RestMethod -Uri $u -UseDefaultCredentials
    Write-Host "OK - XML length: $($r3.value.SDMPackageXML.Length)" -ForegroundColor Green
} catch { Write-Host "FAIL: $($_.Exception.Message)" -ForegroundColor Red }
