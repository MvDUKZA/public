$base = 'https://appsmcm101fp.iprod.local/AdminService'

Write-Host "`n--- A: filter form (no parens) ---" -ForegroundColor Cyan
try {
    $a = Invoke-RestMethod -Uri "$base/wmi/SMS_Application?`$filter=CI_ID eq 16796464&`$select=SDMPackageXML" -UseDefaultCredentials
    Write-Host "OK - got $($a.value.Count) row(s), XML length: $($a.value[0].SDMPackageXML.Length)" -ForegroundColor Green
} catch { Write-Host "FAIL: $($_.Exception.Message)" -ForegroundColor Red }

Write-Host "`n--- B: curl.exe with parens ---" -ForegroundColor Cyan
$out = curl.exe -s --negotiate -u : "$base/wmi/SMS_Application(16796464)?`$select=SDMPackageXML"
if ($out -match 'SDMPackageXML') { Write-Host "OK - curl returned the XML" -ForegroundColor Green }
else { Write-Host "FAIL: $out" -ForegroundColor Red }



curl.exe -s --negotiate -u : "https://appsmcm101fp.iprod.local/AdminService/wmi/SMS_Application(16796464)?`$select=SDMPackageXML"
